# Go Binaries and Build Artifacts
# Anchored to repo root so they match the built binaries, not the cmd/atcr
# source directory (a bare `atcr` pattern also ignores cmd/atcr/*).
bin/
dist/
/atcr
/atcr-mcp
/atcr-mcp-ssee
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test and Coverage Artifacts
*.out
*.cover
*.test
coverage.html
coverage.txt

# Runtime databases
qdrant_fts.db
qdrant_fts.db-shm
qdrant_fts.db-wal

# Environment and Local Settings
.env
.env.local
.env.*.local
*.local.yaml
*.local.yml

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
.classpath

# Planning Specific Files
.planning/.temp/
.planning/.memory/
.planning/**/*.lock
.planning/**/sprint-complete.md
.planning/**/code-review.md
.planning/.locks/
.planning/.config/.active_sprint
.planning/.active_sprint

# atcr workspace runtime outputs (diff cache + reviewer outputs, never committed).
# Committed here (not just .git/info/exclude) so the rule travels to every clone
# and to CI, where the diff cache (up to cache_max_bytes) and review JSON would
# otherwise be untracked-but-not-ignored and catchable by `git add .`.
.atcr/

# Code review session outputs (verification/ tracked; logs are committed)
.planning/**/code-review/claude/
.planning/**/code-review/multi-agent/
.planning/**/code-review/reconciled/
.kimi-code/
