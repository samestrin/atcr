# Go Binaries and Build Artifacts
# Anchored to repo root so they match the built binaries, not the cmd/atcr
# source directory (a bare `atcr` pattern also ignores cmd/atcr/*).
bin/
/atcr
/atcr-mcp
/atcr-mcp-ssee
*.exe
*.exe~
*.dll
*.so
*.dylib

