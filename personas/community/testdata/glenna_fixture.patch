+// Process drops every per-item error on the floor: no log line, no metric, no
+// return — the failure is completely unobservable in production.
+func Process(items []Item) {
+	for _, it := range items {
+		if err := handle(it); err != nil {
+			continue // error swallowed silently: no logging, metric, or trace
+		}
+	}
